{
  "name": "vue-viewports",
  "version": "4.0.0",
  "description": "Named, reactive, matchMedia-based viewport breakpoints for Vue 3 — a tiny plugin and composable.",
  "type": "module",
  "author": {
    "name": "Marco Boffo",
    "email": "marcoboffo.waves@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaccogatto/vue-viewports.git"
  },
  "homepage": "https://github.com/scaccogatto/vue-viewports#readme",
  "bugs": {
    "url": "https://github.com/scaccogatto/vue-viewports/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "viewport",
    "viewports",
    "responsive",
    "breakpoints",
    "media-query",
    "matchmedia",
    "composable",
    "plugin"
  ],
  "sideEffects": false,
  "main": "./dist/vue-viewports.cjs",
  "module": "./dist/vue-viewports.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-viewports.js",
      "require": "./dist/vue-viewports.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.39"
  },
  "engines": {
    "node": ">=20"
  }
}
